{
  "name": "epona",
  "version": "1.0.0",
  "description": "Dark Ages game launcher",
  "main": "./out/main/index.js",
  "author": "Caeldeth",
  "homepage": "https://github.com/hybrasyl/epona",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "electron-vite preview -- --trace-warnings",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "rebuild": "npx @electron/rebuild -f -w da-win32",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:portable": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/cinzel": "^5.2.8",
    "@fontsource/cinzel-decorative": "^5.2.8",
    "@fontsource/crimson-pro": "^5.2.8",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "da-win32": "file:packages/da-win32",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config": "^2.1.0",
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@electron/rebuild": "^4.0.1",
    "@eslint/js": "^9.39.4",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "prettier": "^3.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.4.1",
    "vitest": "^4.1.5"
  }
}
